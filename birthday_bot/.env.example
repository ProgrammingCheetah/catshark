# Copy to .env and fill in. Real environment variables take precedence.
TELOXIDE_TOKEN=
CHAT_ID=
# Optional: hour of day (UTC, 0-23) to post birthday wishes. Defaults to 9.
#BIRTHDAY_HOUR_UTC=9
# Optional: SQLite database file. Defaults to birthdays.db in the working directory.
#DB_PATH=birthdays.db
# Optional: log filter. Defaults to info (audit trail); debug adds decisions
# and SQL statements, trace adds per-message username observation.
#RUST_LOG=info
